<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Groups - must match main app for shared data access -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.br.eng.gustavo.claudespy</string>
	</array>

	<!-- Keychain Sharing - must match main app for E2EE key access -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)br.eng.gustavo.claudespy.shared</string>
	</array>
</dict>
</plist>
