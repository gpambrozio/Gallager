---
import Base from "./Base.astro";
import Hero from "../components/Hero.astro";

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  lede?: string;
}

const { title, description, heroTitle, lede } = Astro.props;
---

<Base title={title} description={description}>
  <Hero class="page-hero--tight" eyebrow="Guide" title={heroTitle} lede={lede} />
  <div class="container" style="padding:0 var(--space-4) var(--space-8);">
    <article class="prose">
      <slot />
    </article>
    <div style="max-width:760px;margin-top:var(--space-6);border-top:2px solid var(--color-divider);padding-top:var(--space-4);">
      <a href="/docs/" class="btn btn-ghost" style="font-size:15px;">← All docs</a>
    </div>
  </div>
</Base>
