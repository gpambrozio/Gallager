---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";

const features = [
  {
    kicker: "Notifications",
    title: "Pings that matter",
    body: "Get notified only when an agent needs permission, asks a question, or finishes — not for every token it prints.",
  },
  {
    kicker: "Layouts",
    title: "Multi-pane, multi-window",
    body: "Split, resize and reorder panes on your Mac — your iPhone mirrors the layout live and can split panes too. Layouts persist per project.",
  },
  {
    kicker: "Review",
    title: "Built-in file & git browser",
    body: "Review the diff an agent just produced without leaving Gallager: browse files, inspect git status and staged changes right next to the terminal.",
  },
  {
    kicker: "Telemetry",
    title: "Token & cost meter",
    body: "A live per-session meter of tokens, cost and latency, fed by each agent's OpenTelemetry stream — know what a session cost at a glance.",
  },
  {
    kicker: "Infrastructure",
    title: "Self-hostable relay",
    body: "One lightweight Vapor server, one docker compose up. Your traffic never touches infrastructure you don't own.",
  },
  {
    kicker: "License",
    title: "Open source",
    body: "The Mac app, iOS app and relay are all MIT-licensed. Audit the crypto, file issues, or fork the whole thing.",
  },
];

const faqs = [
  {
    q: "Which coding agents does Gallager support?",
    a: "Claude Code and Codex CLI work out of the box; opencode and pi are supported through sidecar plugins. Anything that runs in tmux can still be mirrored and streamed as a plain terminal.",
  },
  {
    q: "Do I need an account?",
    a: "No accounts, no email. Pairing is a short one-time code between your Mac and iPhone — the relay just routes encrypted blobs between the two paired devices.",
  },
  {
    q: "What can the relay server see?",
    a: "Ciphertext, timing and the pairing metadata it needs to route — device IDs and names, public keys, push tokens. Terminal content, keystrokes, file paths and hook events are all encrypted end-to-end with keys that exist only on your devices.",
  },
  {
    q: "Does my Mac need to stay awake?",
    a: "Gallager holds a sleep-prevention assertion while sessions are active, so your agents keep running with the lid open. It releases it as soon as they're done.",
  },
  {
    q: "What does it cost?",
    a: "The apps are free and open source. Self-host the relay for free, or use our hosted relay with a paid license if you'd rather not run a server.",
  },
  {
    q: "Is this a chat wrapper around the agents?",
    a: "No — it's the real terminal. Full PTY streams over tmux, with scrollback, mouse support and multi-pane layouts, mirrored bit-for-bit to your phone.",
  },
  {
    q: "Why is it called Gallager?",
    a: "It's named after Robert G. Gallager, a pioneering information theorist at MIT and close colleague of Claude Shannon — after whom Anthropic's Claude is named. Gallager was first created as a companion to Claude Code.",
  },
];
---

<Base
  title="Gallager — command center for your coding agents"
  description="Run every Claude Code, Codex, opencode and pi session on your Mac from one command center — and from your iPhone, end-to-end encrypted."
