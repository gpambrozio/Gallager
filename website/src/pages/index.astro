      id="download"
      style="display:flex;gap:var(--space-3);align-items:center;flex-wrap:wrap;"
    >
      <a
        href="https://updates.gallager.app/Gallager.dmg"
        class="btn btn-primary"
        style="padding:var(--space-3) var(--space-6);font-size:15px;"
        >Download for Mac</a
