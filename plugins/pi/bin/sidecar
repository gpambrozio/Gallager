#!/usr/bin/env python3
"""
Gallager sidecar plugin for pi (https://github.com/earendil-works/pi — the
"pi" AI coding assistant CLI, `@earendil-works/pi-coding-agent`).

A sidecar is a long-lived child process Gallager spawns once and talks to over
stdin/stdout using JSON-RPC with LSP-style `Content-Length` framing. This sidecar
turns pi's extension event-bus events (forwarded by the companion `gallager.ts`
pi extension → Gallager's ingress socket → here as `translate_event` calls) into
the agent-blind `PluginEvent` shape Gallager understands.

pi exposes a rich extension event bus, so unlike some agents the mapping is
direct and unambiguous — no idle/done heuristics:
  - pi.session.start    → the session appears (idle)
  - pi.agent.start      → working (spinner, no badge)
  - pi.agent.end        → doneWorking (attention badge) + a notification
  - pi.session.shutdown → the session is removed (only on a real quit)

Token/cost/latency telemetry rides a SEPARATE channel: the pi extension POSTs one
OTLP/JSON record per completed assistant message straight to Gallager's loopback
receiver (never through the ingress socket). This sidecar only bakes the receiver
endpoint into the extension at install; the manifest's `otlp` block routes the
`pi.` namespace into the per-session meter (issue #617).

Casing reminder (the #1 footgun):
  - plugin.json manifest .......... snake_case
  - ingress *socket* frame ........ snake_case (plugin_id, context, payload)
  - stdio *transport* (this file) . camelCase (pluginID, sessionID, tmuxPane, ...)

IMPORTANT: stdout is the RPC channel. Never `print()` to stdout — it corrupts the
frame stream. Use `log(...)` (Settings → View Logs) or write to stderr.

Run requirements: Python 3.9+. No third-party packages.
"""
import json
import os
import sys

PLUGIN_VERSION = "0.1.0"


# ---------------------------------------------------------------------------
# Framing — read/write one Content-Length-framed JSON message.
# ---------------------------------------------------------------------------
def _read_exactly(n):
    """Read exactly n bytes from stdin, or return None on EOF."""
    buf = bytearray()
    while len(buf) < n:
        chunk = sys.stdin.buffer.read(n - len(buf))
        if not chunk:
            return None
        buf.extend(chunk)
    return bytes(buf)


def read_message():
    """Block until one full message arrives. Returns the decoded dict, or None on EOF."""
    header = b""
    while b"\r\n\r\n" not in header:
        ch = sys.stdin.buffer.read(1)
        if not ch:
            return None  # stdin closed → Gallager is gone
        header += ch
    length = 0
    for line in header.split(b"\r\n"):
        if line.lower().startswith(b"content-length:"):
            length = int(line.split(b":", 1)[1].strip())
    body = _read_exactly(length) if length else b""
    if body is None:
        return None
    return json.loads(body)


def write_message(msg):
    body = json.dumps(msg).encode("utf-8")
    sys.stdout.buffer.write(b"Content-Length: " + str(len(body)).encode() + b"\r\n\r\n" + body)
    sys.stdout.buffer.flush()


def respond(req_id, result):
    write_message({"id": req_id, "result": result})


def fail(req_id, code, message):
    write_message({"id": req_id, "error": {"code": code, "message": message}})


def notify(method, params):
    write_message({"method": method, "params": params})


def log(level, message):
    notify("log", {"level": level, "message": message})


# ---------------------------------------------------------------------------
# AgentState builders (the `state` field of a PluginEvent). Encoding is the
# Swift auto-synthesized tagged-enum form: a single-key object; labeled
# associated values become named keys, unlabeled ones become "_0".
# ---------------------------------------------------------------------------
def state_working():
    return {"working": {}}


def state_done(summary=None):
    return {"doneWorking": {"summary": summary}}


def state_idle():
    return {"idle": {}}


# ---------------------------------------------------------------------------
# Settings + OTLP endpoint (delivered on initialize / apply_settings).
# ---------------------------------------------------------------------------
# Generic sidecar settings (snake_case): command_path, auto_run, log_level,
# additional_config_folders, close_pane_on_session_end.
SETTINGS = {}

# Gallager's loopback OTLP receiver endpoint (e.g. "http://127.0.0.1:24318"),
# delivered on the initialize env (PluginEnvWire.otlpReceiverEndpoint). Baked
# into the pi extension at install so pi — which does not inherit Gallager's
# env — can POST telemetry to it (issue #617). Empty when the receiver failed to
# bind: the install then bakes an empty endpoint and telemetry stays off.
OTLP_ENDPOINT = ""


def _store_settings(value):
    global SETTINGS
    if isinstance(value, dict):
        SETTINGS = value


# ---------------------------------------------------------------------------
# pi event → PluginEvent mapping.
# ---------------------------------------------------------------------------
def _project_name(project_path):
    if not project_path:
        return None
    return os.path.basename(project_path.rstrip("/")) or project_path


def _done_body(project_path):
    name = _project_name(project_path)
    return ("Finished — %s" % name) if name else "Ready for input"


def handle_translate_event(req_id, params):
    context = params.get("context") or {}
    payload = params.get("payload") or {}

    tmux_pane = context.get("TMUX_PANE")
    project_path = context.get("PI_PROJECT_DIR")
    plugin_id = params.get("pluginID")

    etype = payload.get("type")
    props = payload.get("properties") or {}

    # pi's own session id (a UUID) is the stable per-session key, and the same id
    # the extension stamps on its OTLP `session.id` so the meter joins. Fall back
    # to the pane if a frame somehow lacks it.
    session_id = props.get("sessionID") or tmux_pane or "unknown"

    state = None
    notification = None
    app_actions = []

    if etype == "pi.session.start":
        # pi fires this on launch (and on session switch / reload). Nothing else
        # makes the session appear before the first turn — the host's process
        # scan only re-detects on pane add/remove — so surface it as idle right
        # away (mirrors Claude Code's SessionStart → .idle, no notification). On a
        # session switch the new id re-stamps the pane's join key, resetting the
        # meter like `/clear`.
        state = state_idle()

    elif etype == "pi.agent.start":
        # The agent loop started (user submitted a prompt) → working.
        state = state_working()

    elif etype == "pi.agent.end":
        # The agent loop ended (turn complete, control back to the user) →
        # doneWorking raises the attention badge. `summary` is the last assistant
        # line the extension extracted (may be None).
        summary = props.get("summary") or None
        state = state_done(summary)
        notification = {"title": "pi", "body": summary or _done_body(project_path)}

    elif etype == "pi.session.shutdown":
        # pi tears the extension down on quit, /reload, and session replacement
        # (new/resume/fork). Only a real "quit" means the pane's agent is gone —
        # end the session then (AppAction.sessionEnded drops the sidebar row and
        # resets the pane's session-scoped state, keyed by the PANE id, honoring
        # close_pane_on_session_end). The other reasons are followed by a fresh
        # pi.session.start, so leave the pane's session in place.
        if (props.get("reason") == "quit") and tmux_pane:
            close_eligible = bool(SETTINGS.get("close_pane_on_session_end", False))
            app_actions.append({
                "sessionEnded": {"sessionID": tmux_pane, "closePaneEligible": close_eligible},
            })

    if state is None and notification is None and not app_actions:
        respond(req_id, None)  # nothing interesting — ignore this event
        return

    # `appActions` is NON-optional in Swift's PluginEvent — its synthesized
    # Decodable requires the key (the memberwise default is not used at decode).
    # Omitting it makes the host's `decode(PluginEvent.self)` throw and silently
    # drop the whole event, so the session never updates. Always send it.
    respond(req_id, {
        "pluginID": plugin_id,
        "sessionID": session_id,
        "state": state,
        "notification": notification,
        "appActions": app_actions,
        "tmuxPane": tmux_pane,
        "projectPath": project_path,
    })


# ---------------------------------------------------------------------------
# Install / uninstall the pi extension bridge.
#
# pi auto-discovers extensions from `~/.pi/agent/extensions/*.ts` (global, all
# projects) and `<project>/.pi/extensions/*.ts` (project-local). We drop our
# `gallager.ts` there, substituting the ingress socket path, plugin id, and OTLP
# endpoint (pi does not inherit Gallager's env, so they must be baked in).
# ---------------------------------------------------------------------------
_INSTALL_MARKER = "GallagerPiMonitor"  # a distinctive symbol in the extension


def _agent_config_dir():
    # pi honors PI_CODING_AGENT_DIR; default is ~/.pi/agent.
    return os.environ.get("PI_CODING_AGENT_DIR") or os.path.expanduser("~/.pi/agent")


def _extension_dest(config_root=None):
    """Where the extension installs for a given config root.

    The default settings row passes configRoot=None → pi's global extensions dir.
    An additional-folder row passes a project root → that project's
    `.pi/extensions/` so pi loads it for that project only.
    """
    if config_root:
        return os.path.join(os.path.expanduser(config_root), ".pi", "extensions", "gallager.ts")
    return os.path.join(_agent_config_dir(), "extensions", "gallager.ts")


def handle_install(req_id, params):
    sock = os.environ.get("GALLAGER_INGRESS_SOCK", "")
    plugin_id = os.environ.get("GALLAGER_PLUGIN_ID", "pi")
    plugin_root = os.environ.get("GALLAGER_PLUGIN_ROOT", os.getcwd())
    template = os.path.join(plugin_root, "pi-extension", "gallager.ts")
    dest = _extension_dest((params or {}).get("configRoot"))
    try:
        with open(template, "r", encoding="utf-8") as f:
            content = f.read()
        content = content.replace("__GALLAGER_INGRESS_SOCK__", sock)
        content = content.replace("__GALLAGER_PLUGIN_ID__", plugin_id)
        content = content.replace("__GALLAGER_OTLP_ENDPOINT__", OTLP_ENDPOINT)
        os.makedirs(os.path.dirname(dest), exist_ok=True)
        tmp = dest + ".tmp"
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(content)
        os.replace(tmp, dest)
        respond(req_id, {"installed": {"message": "pi extension installed at %s" % dest}})
    except Exception as exc:
        fail(req_id, "install_error", str(exc))


def handle_uninstall(req_id, params):
    try:
        os.remove(_extension_dest((params or {}).get("configRoot")))
    except FileNotFoundError:
        pass
    except Exception as exc:
        sys.stderr.write("uninstall error: %s\n" % exc)
    respond(req_id, {})


def handle_install_status(req_id, params):
    dest = _extension_dest((params or {}).get("configRoot"))
    try:
        with open(dest, "r", encoding="utf-8") as f:
            installed = _INSTALL_MARKER in f.read()
    except OSError:
        installed = False
    if installed:
        respond(req_id, {"installed": {"version": PLUGIN_VERSION}})
    else:
        respond(req_id, {"notInstalled": {}})


# ---------------------------------------------------------------------------
# Project discovery — surface pi's projects in Gallager's "+" sidebar menu, the
# same way Claude Code / Codex / opencode do.
#
# pi stores sessions per project under `~/.pi/agent/sessions/<slug>/*.jsonl`,
# where <slug> is a lossy slugification of the cwd (`/`→`-`). Rather than reverse
# the slug (ambiguous), read the newest session file's first line — a
# `{"type":"session", ..., "cwd":"<real path>"}` record that carries the exact,
# un-slugified project directory. Best-effort: any failure yields an empty list.
# ---------------------------------------------------------------------------
# Seconds between 1970-01-01 and 2001-01-01. AgentProject.lastUsed decodes with a
# default JSONDecoder (`.deferredToDate`) → seconds since the 2001 reference date.
_EPOCH_2001 = 978307200.0


def _sessions_dir():
    return os.path.join(_agent_config_dir(), "sessions")


def _newest_session_file(dir_path):
    newest = None
    newest_mtime = -1.0
    try:
        entries = os.listdir(dir_path)
    except OSError:
        return None
    for name in entries:
        if not name.endswith(".jsonl"):
            continue
        full = os.path.join(dir_path, name)
        try:
            mtime = os.path.getmtime(full)
        except OSError:
            continue
        if mtime > newest_mtime:
            newest_mtime = mtime
            newest = full
    return newest


def _session_header(path):
    """Parse the first JSONL line of a pi session file. Returns the `session`
    header dict (with `cwd`), or None."""
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            first = f.readline()
    except OSError:
        return None
    if not first.strip():
        return None
    try:
        header = json.loads(first)
    except (ValueError, TypeError):
        return None
    if isinstance(header, dict) and header.get("type") == "session":
        return header
    return None


def _scan_projects():
    """Read pi's project list from its session store. Best-effort and
    schema-tolerant — any failure yields an empty list (never raises)."""
    sessions = _sessions_dir()
    if not os.path.isdir(sessions):
        return []
    projects = []
    seen = set()
    try:
        slugs = os.listdir(sessions)
    except OSError:
        return []
    for slug in slugs:
        dir_path = os.path.join(sessions, slug)
        if not os.path.isdir(dir_path):
            continue
        newest = _newest_session_file(dir_path)
        if not newest:
            continue
        header = _session_header(newest)
        cwd = (header or {}).get("cwd")
        if not cwd or cwd in seen or not os.path.isdir(cwd):
            continue
        seen.add(cwd)
        proj = {
            "name": os.path.basename(cwd.rstrip("/")) or cwd,
            "path": cwd,
            "pluginID": "pi",
        }
        try:
            proj["lastUsed"] = os.path.getmtime(newest) - _EPOCH_2001
        except OSError:
            pass
        projects.append(proj)
    return projects


def _emit_projects():
    notify("set_projects", {"projects": _scan_projects()})


def handle_refresh_projects(req_id, params):
    _emit_projects()
    respond(req_id, {})


# ---------------------------------------------------------------------------
# Remaining RPC handlers.
# ---------------------------------------------------------------------------
def handle_initialize(req_id, params):
    global OTLP_ENDPOINT
    _store_settings((params or {}).get("settings"))
    OTLP_ENDPOINT = (params or {}).get("otlpReceiverEndpoint") or ""
    log("info", "pi sidecar initialized (app %s)" % (params or {}).get("appVersion", "?"))
    respond(req_id, {})
    _emit_projects()  # seed the sidebar before the first refresh tick


def handle_command_for_launch(req_id, params):
    # Honor the user's Agents-settings toggles (delivered via apply_settings).
    if not SETTINGS.get("auto_run", True):
        respond(req_id, None)  # auto-run off → don't launch
        return
    command = (SETTINGS.get("command_path") or "").strip() or "pi"
    respond(req_id, {"command": command, "args": [], "env": {}})


def handle_apply_settings(req_id, params):
    _store_settings((params or {}).get("settings"))
    respond(req_id, {"applied": {}})


REQUEST_HANDLERS = {
    "initialize": handle_initialize,
    "translate_event": handle_translate_event,
    "command_for_launch": handle_command_for_launch,
    "install": handle_install,
    "uninstall": handle_uninstall,
    "install_status": handle_install_status,
    "apply_settings": handle_apply_settings,
    "refresh_projects": handle_refresh_projects,
}


def main():
    while True:
        try:
            msg = read_message()
        except Exception as exc:
            sys.stderr.write("read error: %s\n" % exc)
            continue
        if msg is None:
            break  # EOF

        method = msg.get("method")
        req_id = msg.get("id")
        if method is None:
            continue  # a stray response/notification — ignore

        if method == "shutdown":
            respond(req_id, {})
            break

        handler = REQUEST_HANDLERS.get(method)
        if handler is not None:
            try:
                handler(req_id, msg.get("params"))
            except Exception as exc:
                sys.stderr.write("handler error in %s: %s\n" % (method, exc))
                if req_id is not None:
                    fail(req_id, "internal_error", str(exc))
        elif req_id is not None:
            fail(req_id, "method_not_found", "Unknown method: %s" % method)


if __name__ == "__main__":
    main()
