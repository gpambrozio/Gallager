<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Apple Events - required for AppleScript automation (terminal launching) -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>

	<!-- Network client - required for downloading updates -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Disable library validation - DEBUG ONLY -->
	<!-- Required because Sparkle.framework has a different Team ID when loaded via SPM -->
	<!-- See: https://sparkle-project.org/documentation/#1-add-the-sparkle-framework-to-your-project -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
