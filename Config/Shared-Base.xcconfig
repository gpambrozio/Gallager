// Shared-Base.xcconfig
// Version numbers shared across all targets (iOS + macOS)

// ==========================================
// Versioning
// ==========================================
MARKETING_VERSION = 1.26
CURRENT_PROJECT_VERSION = 26

// ==========================================
// Build Performance
// ==========================================
// Cache compilation results across builds (branch switching, clean builds)
COMPILATION_CACHE_ENABLE_CACHING = YES
// Allow linker to start before all compilation finishes
EAGER_LINKING = YES
