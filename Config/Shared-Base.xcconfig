// Shared-Base.xcconfig
// Version numbers shared across all targets (iOS + macOS)

// ==========================================
// Versioning
// ==========================================
// Bumped to 2.0 for the plugin-system flag-day wire break: the host/viewer
// minimum-compatible version (VersionCompatibility) is 2.0, so the app's own
// marketing version must be >= 2.0 or same-version peers reject each other.
MARKETING_VERSION = 2.1
CURRENT_PROJECT_VERSION = 34

// ==========================================
// Build Performance
// ==========================================
// Cache compilation results across builds (branch switching, clean builds)
COMPILATION_CACHE_ENABLE_CACHING = YES
// Allow linker to start before all compilation finishes
EAGER_LINKING = YES
