{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \"$file_path\" | grep -q '\\.swift$'; then swiftformat \"$file_path\"; fi; }",
            "type": "command"
          }
        ],
        "matcher": "Edit|MultiEdit|Write"
      }
    ]
  },
  "extraKnownMarketplaces": {
    "ClaudeCodePlugins": {
      "source": {
        "source": "github",
        "repo": "gpambrozio/ClaudeCodePlugins"
      }
    },
    "swift-concurrency-agent-skill": {
      "source": {
        "source": "github",
        "repo": "AvdLee/Swift-Concurrency-Agent-Skill"
      }
    },
    "swiftui-expert-skill": {
      "source": {
        "source": "github",
        "repo": "AvdLee/SwiftUI-Agent-Skill"
      }
    }
  },
  "enabledPlugins": {
    "XcodeBuildTools@ClaudeCodePlugins": true,
    "iOSSimulator@ClaudeCodePlugins": true,
    "swift-concurrency@swift-concurrency-agent-skill": true,
    "swiftui-expert@swiftui-expert-skill": true
  }
}
