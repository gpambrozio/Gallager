{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \"$file_path\" | grep -q '\\.swift$'; then swiftformat \"$file_path\"; fi; }"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "XcodeBuildTools@ClaudeCodePlugins": true,
    "iOSSimulator@ClaudeCodePlugins": true,
    "SwiftDevelopment@ClaudePrivate": true
  },
  "extraKnownMarketplaces": {
    "ClaudeCodePlugins": {
      "source": {
        "source": "github",
        "repo": "gpambrozio/ClaudeCodePlugins"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  }
}
