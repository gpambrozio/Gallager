# ClaudeSpy/Gallager Relay Server
# This file should be placed in /etc/caddy/conf.d/
#
# relay.gallager.app is the canonical hostname; claudespy.gustavo.eng.br is
# kept as a legacy alias so existing clients (which have the old URL saved) keep
# connecting. Caddy issues a cert for each hostname; both proxy to the same relay.

relay.gallager.app, claudespy.gustavo.eng.br {
    # Reverse proxy to the relay server
    reverse_proxy localhost:8080

    # WebSocket support is automatic in Caddy
    # No special configuration needed

    # Access logging
    log {
        output file /var/log/caddy/claudespy-access.log
        format json
    }

    # Security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "DENY"
        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"
        # Enable XSS protection
        X-XSS-Protection "1; mode=block"
    }
}
