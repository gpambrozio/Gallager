# Gallager update hosting (Sparkle appcast + DMGs + plugin bundles)
# This file should be placed in /etc/caddy/conf.d/ (deploy.sh installs it
# alongside claudespy.caddy on every prod deploy).
#
# Serves static files from /opt/claudespy-updates, uploaded by
# scripts/release.sh over rsync/SSH:
#   ClaudeSpy.xml            Sparkle appcast
#   Gallager-<version>.dmg   versioned releases
#   Gallager.dmg             canonical copy of the latest release
#   plugins/<id>/            sidecar plugin bundles + distribution manifests
#
# updates.gustavo.eng.br is the legacy hostname baked into every shipped app's
# SUFeedURL, so it must keep serving the appcast indefinitely. Add it as an
# alias here ONLY AFTER its DNS points at this server (issue #664 task 5) —
# if Caddy sees the hostname before DNS flips, ACME cert issuance fails and
# retries noisily:
#
#   updates.gallager.app, updates.gustavo.eng.br {

updates.gallager.app {
    root * /opt/claudespy-updates
    file_server

    # Access logging (separate file from the relay)
    log {
        output file /var/log/caddy/gallager-updates-access.log
        format json
    }

    # Security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "DENY"
        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"
        # Enable XSS protection
        X-XSS-Protection "1; mode=block"
    }
}
