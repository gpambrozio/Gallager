# APNs Configuration for Push Notifications
# Copy this file to .env and fill in your values

# Path to your APNs authentication key (.p8 file)
# Download from Apple Developer Portal > Certificates, Identifiers & Profiles > Keys
APNS_KEY_PATH=/secrets/AuthKey.p8

# Key ID from Apple Developer Portal (10-character string)
APNS_KEY_ID=

# Team ID from Apple Developer Portal (10-character string)
APNS_TEAM_ID=

# Bundle ID of your iOS app
APNS_BUNDLE_ID=com.yourcompany.ClaudeSpy

# APNs environment: "development" for Xcode builds, "production" for App Store/TestFlight
APNS_ENVIRONMENT=development

# Optional: Set log level (debug, info, notice, warning, error, critical)
# Default is 'warning' - set to 'info' or 'debug' for more verbose logging
# LOG_LEVEL=warning

# Optional: Pairing code expiry in seconds (default: 300 = 5 minutes)
PAIRING_CODE_EXPIRY_SECONDS=300
