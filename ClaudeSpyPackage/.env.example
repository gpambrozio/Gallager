# ClaudeSpy Relay Server Configuration
# Copy this file to .env and customize as needed
#
# For detailed setup instructions, see: docs/self-hosting.md

# ============================================================================
# SERVER SETTINGS
# ============================================================================

# Log level: debug, info, notice, warning, error, critical
# Default is 'warning' - use 'info' or 'debug' for troubleshooting
LOG_LEVEL=warning

# Pairing code expiry in seconds (default: 300 = 5 minutes)
# Increase for slower setup scenarios, decrease for tighter security
PAIRING_CODE_EXPIRY_SECONDS=300

# ============================================================================
# MONITORING (OPTIONAL)
# ============================================================================

# Bearer token required to scrape GET /metrics. Generate with:
#   openssl rand -hex 32
# Must match the token configured in monitoring/agents/config.alloy on the VM.
# Leave empty to disable the /metrics endpoint (it will reject all requests).
METRICS_TOKEN=

# ============================================================================
# LICENSING (HOSTED-RELAY MONETIZATION — OPTIONAL)
# ============================================================================
# Self-hosting? Leave this whole section unset: the relay runs unrestricted.
#
# On the official hosted relay these gate host Macs behind a Lemon Squeezy
# subscription (7-day trial auto-starts on first use). Both ids come from the
# Lemon Squeezy dashboard; setting only one of them fails boot on purpose.
# A present but non-integer value in ANY of these vars also fails boot;
# only fully unset/empty vars fall back to defaults.

# Numeric store id from Lemon Squeezy → Settings → Stores
LEMONSQUEEZY_STORE_ID=

# Numeric product id of the subscription product
LEMONSQUEEZY_PRODUCT_ID=

# Trial length in days (default 7)
TRIAL_DAYS=7

# How often cached license verdicts are revalidated against Lemon Squeezy (default 24)
LICENSE_REVALIDATE_HOURS=24

# How long a previously-valid key keeps working while Lemon Squeezy is
# unreachable (default 7). Hard expired/disabled verdicts block immediately.
LICENSE_GRACE_DAYS=7

# ============================================================================
# PUSH NOTIFICATIONS (OPTIONAL)
# ============================================================================
# Push notifications allow the iOS app to receive alerts when not actively
# connected via WebSocket. Skip this section if you don't need push notifications.
#
# To enable push notifications:
# 1. Create an APNs Key in Apple Developer Portal
#    (Certificates, Identifiers & Profiles > Keys > Create a Key with APNs)
# 2. Download the .p8 file and place it in ./secrets/AuthKey.p8
# 3. Fill in the values below

# Path to your APNs authentication key (.p8 file)
# The file should be placed in ./secrets/ directory
APNS_KEY_PATH=/secrets/AuthKey.p8

# Key ID from Apple Developer Portal (10-character string)
# Found when you create/view the APNs key
APNS_KEY_ID=

# Team ID from Apple Developer Portal (10-character string)
# Found at: https://developer.apple.com/account > Membership Details
APNS_TEAM_ID=

# Bundle ID of your iOS app
# Must match your iOS app's bundle identifier exactly
APNS_BUNDLE_ID=com.yourcompany.ClaudeSpy

# APNs environment:
# - "development" for apps built with Xcode (debug builds)
# - "production" for apps from App Store or TestFlight
APNS_ENVIRONMENT=development
