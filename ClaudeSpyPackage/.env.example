# ClaudeSpy Relay Server Configuration
# Copy this file to .env and customize as needed
#
# For detailed setup instructions, see: docs/self-hosting.md

# ============================================================================
# SERVER SETTINGS
# ============================================================================

# Log level: debug, info, notice, warning, error, critical
# Default is 'warning' - use 'info' or 'debug' for troubleshooting
LOG_LEVEL=warning

# Pairing code expiry in seconds (default: 300 = 5 minutes)
# Increase for slower setup scenarios, decrease for tighter security
PAIRING_CODE_EXPIRY_SECONDS=300

# ============================================================================
# PUSH NOTIFICATIONS (OPTIONAL)
# ============================================================================
# Push notifications allow the iOS app to receive alerts when not actively
# connected via WebSocket. Skip this section if you don't need push notifications.
#
# To enable push notifications:
# 1. Create an APNs Key in Apple Developer Portal
#    (Certificates, Identifiers & Profiles > Keys > Create a Key with APNs)
# 2. Download the .p8 file and place it in ./secrets/AuthKey.p8
# 3. Fill in the values below

# Path to your APNs authentication key (.p8 file)
# The file should be placed in ./secrets/ directory
APNS_KEY_PATH=/secrets/AuthKey.p8

# Key ID from Apple Developer Portal (10-character string)
# Found when you create/view the APNs key
APNS_KEY_ID=

# Team ID from Apple Developer Portal (10-character string)
# Found at: https://developer.apple.com/account > Membership Details
APNS_TEAM_ID=

# Bundle ID of your iOS app
# Must match your iOS app's bundle identifier exactly
APNS_BUNDLE_ID=com.yourcompany.ClaudeSpy

# APNs environment:
# - "development" for apps built with Xcode (debug builds)
# - "production" for apps from App Store or TestFlight
APNS_ENVIRONMENT=development
