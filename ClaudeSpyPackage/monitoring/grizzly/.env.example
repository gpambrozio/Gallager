# Set these before running `make apply`.
GRAFANA_URL=https://<your-stack>.grafana.net
GRAFANA_TOKEN=<service-account-token-from-task-12>
DISCORD_WEBHOOK_URL=<discord-webhook-url-from-task-15>
ALERT_FOLDER=ClaudeSpy
# UID of the Grafana Cloud Prometheus datasource (capture via `grr pull`).
PROM_DS_UID=<grafanacloud-prometheus-uid>
