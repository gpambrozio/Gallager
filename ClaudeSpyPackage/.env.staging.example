# Gallager Relay Server — STAGING environment
#
# Copy this to /opt/claudespy-staging/.env ON THE SERVER (never the prod dir),
# then fill in the placeholders. This enables hosted-relay licensing in Lemon
# Squeezy TEST MODE so the full trial → blocked → activate flow can be exercised
# without real charges.
#
# `scripts/deploy.sh staging` deliberately EXCLUDES .env and secrets/ from the
# rsync, so this file lives only on the server: a staging deploy never overwrites
# it, and a prod deploy never touches it. See docs/staging-relay.md.

# ============================================================================
# SERVER SETTINGS
# ============================================================================
# 'info' is handy while testing staging; drop to 'warning' to match prod.
LOG_LEVEL=info
PAIRING_CODE_EXPIRY_SECONDS=300

# Minimum client version gate (optional). Handy to exercise on staging before
# enabling on prod: set a version above your test build's to see the connect-time
# "please update" rejection, or leave unset to accept every client.
# MIN_CLIENT_VERSION=
# MIN_CLIENT_VERSION_REJECT_UNKNOWN=false

# ============================================================================
# LICENSING — ENABLED (Lemon Squeezy TEST MODE)
# ============================================================================
# Test mode vs live mode in Lemon Squeezy is selected by using a TEST-MODE store,
# product, and license keys — all against the normal api.lemonsqueezy.com base.
# So for staging:
#   1. In Lemon Squeezy, toggle "Test mode" (top-right).
#   2. Create the store + subscription product in test mode (or reuse existing).
#   3. Put the TEST-MODE numeric ids below (Settings → Stores for the store id;
#      the product's page for the product id).
#   4. Generate test-mode license keys to activate against this staging relay.
#   5. Leave LEMONSQUEEZY_API_BASE UNSET — test vs live is keyed by the license,
#      not by a different URL.
LEMONSQUEEZY_STORE_ID=REPLACE_WITH_TEST_STORE_ID
LEMONSQUEEZY_PRODUCT_ID=REPLACE_WITH_TEST_PRODUCT_ID

# Optional tuning. Shorten TRIAL_DAYS (e.g. 1) to make trial-expiry testing fast.
# Constraint enforced at boot: LICENSE_REVALIDATE_HOURS < LICENSE_GRACE_DAYS × 24.
TRIAL_DAYS=7
LICENSE_REVALIDATE_HOURS=24
LICENSE_GRACE_DAYS=7

# Leave UNSET for real Lemon Squeezy test mode. Only set this to point at the
# E2E stub server — deterministic and offline, but it does NOT prove the real
# Lemon Squeezy integration, so it's for quick smoke tests only.
# LEMONSQUEEZY_API_BASE=

# ============================================================================
# MONITORING (OPTIONAL)
# ============================================================================
# The prod Alloy agent only scrapes prod's port, so staging metrics aren't
# collected. Leave unset, or set a distinct token if you want to curl /metrics.
METRICS_TOKEN=

# ============================================================================
# PUSH NOTIFICATIONS
# ============================================================================
# Reuse the same APNs key as prod: place it at
#   /opt/claudespy-staging/secrets/AuthKey.p8
# and copy the APNS_KEY_ID / APNS_TEAM_ID / APNS_BUNDLE_ID values from your prod
# .env verbatim. Set APNS_ENVIRONMENT to match the TEST build you point at
# staging: 'development' for an Xcode debug build, 'production' for TestFlight.
APNS_KEY_PATH=/secrets/AuthKey.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.yourcompany.ClaudeSpy
APNS_ENVIRONMENT=development
